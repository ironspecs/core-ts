{
  "name": "core-ts",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "build": "bun run --filter='*' --workspaces build",
    "test": "bun run --parallel --workspaces test",
    "typecheck": "bun run --parallel --workspaces typecheck",
    "lint": "bun run --parallel --workspaces lint",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "check:dependencies": "./scripts/check-dependency-versions.sh",
    "pre-commit": "./scripts/pre-commit-checks.sh",
    "pre-push": "./scripts/pre-push-checks.sh"
  },
  "workspaces": [
    "react",
    "react-form-builder",
    "react-i18n",
    "react-progression",
    "oxlint-plugin-tailwind",
    "oxlint-plugin-types"
  ],
  "author": "Dane Stuckel",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git@github.com:ironspecs/core-ts.git"
  },
  "devDependencies": {
    "@types/react": "^19.1.15",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "^3.4.2",
    "typescript": "~5.7.2"
  },
  "packageManager": "bun@1.3.10"
}
